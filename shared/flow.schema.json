{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Vaak conversation flow",
  "description": "A versioned conversation flow (data, not code — MULTI_AGENT_SPEC §1.5). Loaded by the caller-agent (WP-3); opt-out branches are enforced by the compliance-agent (WP-5), fail-closed.",
  "type": "object",
  "required": ["id", "version", "persona", "goal", "steps"],
  "properties": {
    "id": { "type": "string" },
    "version": { "type": "string" },
    "persona": { "type": "string" },
    "vertical": { "type": "string" },
    "project": { "type": "object" },
    "goal": { "type": "string" },
    "globals": { "type": "object" },
    "steps": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "say"],
        "properties": {
          "id": { "type": "string" },
          "say": { "type": "string" },
          "capture": { "type": "string" },
          "next": { "type": "string" },
          "branch": { "type": "object" },
          "tool": { "type": "string" },
          "disclosure": { "type": "boolean" },
          "end": { "type": "boolean" },
          "optout": { "type": "boolean" }
        }
      }
    }
  }
}
