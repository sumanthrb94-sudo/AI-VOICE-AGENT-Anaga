# Vaak AI — environment sample (WP-0). Copy to .env and fill. NEVER commit real secrets.

# --- Telephony (160-series, compliant) ---
PLIVO_AUTH_ID=
PLIVO_AUTH_TOKEN=
EXOTEL_SID=
EXOTEL_TOKEN=
OUTBOUND_CALLER_ID=        # must be a 160-series number

# --- Agent identity & voice ---
AGENT_NAME=Anaga
AGENT_PERSONA=caller-agent/flows/anaga.persona.json
TTS_VOICE_GENDER=female
TTS_SPEAKER=anushka        # Sarvam Bulbul female voice; verify id against current Sarvam docs

# --- Speech (provider-abstracted; Sarvam default) ---
# SARVAM_API_KEY powers the live "Talk to Anaga" voices via /api/tts (Bulbul) AND
# the auto-language speech-to-text via /api/stt (Saarika). Set it in Vercel
# (server-side only). Without it, the browser TTS + Web Speech fallbacks are used.
SARVAM_API_KEY=
TTS_PROVIDER=sarvam        # sarvam | (future: elevenlabs, azure, gcloud)
SARVAM_TTS_MODEL=bulbul:v2
STT_PROVIDER=sarvam        # sarvam | (future: deepgram, gcloud, whisper)
SARVAM_STT_MODEL=saarika:v2.5   # auto-detects language when client sends language_code "unknown"
# AI4BHARAT_API_KEY=       # alternate STT/TTS adapter

# --- LLM (provider-abstracted) ---
LLM_PROVIDER=gemini        # gemini | hosted | ollama | vllm  (Anaga call-brain default: gemini)
LLM_API_KEY=
LLM_BASE_URL=

# Google Gemini (powers the live "Talk to Anaga" call brain + call review).
# Set this in Vercel Project Settings → Environment Variables (server-side only;
# it must NEVER be exposed to the browser). Verify the model name against current
# Google AI docs. If unset, the call demo falls back to the on-device rule engine.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ===================================================================
# PRODUCTION IVR + WHATSAPP ORCHESTRATION  (docs/PRODUCTION_TELEPHONY.md)
# Send Anaga a phone number on WhatsApp -> she calls the lead in ~1s,
# qualifies in Telugu, then WhatsApps you the outcome.
# ===================================================================

# --- Managed voice platform (runs Anaga on a real phone line) ---
VOICE_PLATFORM=samvaad           # samvaad (default, India-native) | vapi | retell

# Sarvam Samvaad (https://dashboard.sarvam.ai → Samvaad). India-native voice +
# WhatsApp + Telugu, self-serve. Build the "Anaga" agent in the dashboard: paste
# SYL_RULES (api/_lib/prompts.js) as the instructions + the Telugu opening line as
# the first message, choose a Sarvam Telugu FEMALE voice, enable language switch,
# connect telephony (Exotel) and/or WhatsApp. Reuses your existing SARVAM_API_KEY.
SAMVAAD_AGENT_ID=                # the Anaga agent id from the Samvaad dashboard
SAMVAAD_OUTBOUND_URL=            # the outbound-call endpoint from Samvaad's API docs (copy verbatim)
SAMVAAD_FROM_NUMBER=             # optional caller-id (your DLT-approved Exotel number)

# Vapi (https://docs.vapi.ai) — only if VOICE_PLATFORM=vapi
VAPI_API_KEY=
VAPI_PHONE_NUMBER_ID=            # the Exotel BYO-SIP number registered in Vapi (dials FROM this)
VAPI_ASSISTANT_ID=               # PREFERRED: configure voice/model/transcriber in the Vapi dashboard.
                                 # If unset, an inline Anaga assistant is built from SYL_RULES (below).
# Retell (https://docs.retellai.com) — only if VOICE_PLATFORM=retell
RETELL_API_KEY=
RETELL_FROM_NUMBER=              # Exotel number registered in Retell (E.164)
RETELL_AGENT_ID=

# Inline-assistant bootstrap (used only when VAPI_ASSISTANT_ID is unset).
# VERIFY ids against current platform docs; for best Telugu, point STT/TTS at a
# Telugu-capable provider (e.g. Sarvam) here or in the dashboard.
VOICE_LLM_PROVIDER=google        # google | openai | anthropic | …
VOICE_LLM_MODEL=gemini-2.0-flash
VOICE_TTS_PROVIDER=              # e.g. sarvam | 11labs | azure  (optional)
VOICE_TTS_VOICE_ID=              # a FEMALE, Telugu-capable voice id (optional)
VOICE_STT_PROVIDER=              # e.g. sarvam | deepgram         (optional)
VOICE_STT_LANGUAGE=              # e.g. multi | te                (optional)
VOICE_WEBHOOK_URL=               # https://<your-app>/api/voice/webhook (end-of-call report)
VOICE_WEBHOOK_SECRET=            # echoed by the platform; verified by /api/voice/webhook

# Shared secret required to trigger a call via POST /api/calls/outbound.
# Generate a long random string:  openssl rand -hex 32
CALL_TRIGGER_SECRET=

# --- WhatsApp (Meta Cloud API; free to start, swappable to a BSP later) ---
WHATSAPP_TOKEN=                  # permanent System-User access token (Meta Business)
WHATSAPP_PHONE_NUMBER_ID=        # the WhatsApp Business phone-number id
WHATSAPP_VERIFY_TOKEN=           # any string you choose; echoed back in the GET handshake
WHATSAPP_APP_SECRET=             # Meta App secret — verifies inbound webhook signatures (REQUIRED in prod)
WHATSAPP_GRAPH_VERSION=v21.0     # Graph API version (optional)

# --- Compliance (fails closed: no creds => no dial) ---
DLT_PRINCIPAL_ENTITY_ID=
DLT_HEADER=
DND_SCRUB_API_KEY=
RECORDING_BUCKET=          # Indian-region object storage
RECORDING_RETENTION_DAYS=90

# --- Datastore ---
DATABASE_URL=
SUPPRESSION_LIST_URL=

# --- Observability ---
OTEL_EXPORTER_OTLP_ENDPOINT=
